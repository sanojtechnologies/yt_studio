{
  "name": "yt_studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "WATCHPACK_POLLING=true next dev",
    "dev:reset": "rm -rf .next && WATCHPACK_POLLING=true next dev",
    "build": "npm run verify:strict && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit tests/integration",
    "test:live": "vitest run tests/live",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "coverage": "vitest run --coverage",
    "prd:check": "node scripts/check-prd-sync.mjs",
    "verify:strict": "npm run coverage && npm run lint && npm run typecheck && npm run prd:check"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "googleapis": "^171.4.0",
    "next": "14.2.5",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
